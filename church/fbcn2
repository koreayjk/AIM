<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>First Bible Church Normangee</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --blush:#eef1ea; --blush2:#e1e7d9; --card:#fbfbf5; --cream:#fcfcf6;
  --wine:#2f5d4f; --wine2:#214339; --rose:#7fa088;
  --ink:#22302a; --ink2:#54615a; --line:#d6ddcc;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Hanken Grotesk',sans-serif;background:var(--blush);color:var(--ink);line-height:1.6;overflow-x:hidden}
h1,h2,h3,.serif{font-family:'Fraunces',serif}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
.wrap{max-width:1180px;margin:0 auto;padding:0 24px}
.btn{display:inline-flex;align-items:center;gap:10px;background:var(--wine);color:#fff;
  padding:15px 30px;border-radius:40px;font-weight:700;font-size:.95rem;letter-spacing:.2px;
  border:none;cursor:pointer;transition:.25s;box-shadow:0 10px 26px -10px rgba(47,93,79,.6)}
.btn:hover{background:var(--wine2);transform:translateY(-2px);box-shadow:0 16px 30px -10px rgba(47,93,79,.7)}
.btn.ghost{background:transparent;color:var(--wine);box-shadow:none;text-decoration:underline;text-underline-offset:5px;padding:15px 8px}
.btn.ghost:hover{transform:none;color:var(--wine2)}
.arrow{display:inline-block;transition:.25s}
.btn:hover .arrow{transform:translate(3px,-3px)}

/* announcement */
.ann{background:var(--wine);color:#f7e9ee;text-align:center;font-size:.82rem;font-weight:600;letter-spacing:.6px;padding:9px 16px}
.ann b{color:#fff}

/* nav */
header{position:sticky;top:0;z-index:50;background:rgba(243,231,235,.86);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
nav{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;max-width:1180px;margin:0 auto}
.logo{display:flex;align-items:center;gap:12px}
.logo .mark{width:40px;height:40px;flex:none;display:grid;place-items:center}
.logo .mark svg{width:40px;height:40px}
.logo b{font-family:'Fraunces',serif;font-weight:600;font-size:1.18rem;line-height:1.05;color:var(--wine)}
.logo span{display:block;font-family:'Hanken Grotesk';font-weight:700;font-size:.62rem;letter-spacing:3px;color:var(--ink2);text-transform:uppercase;margin-top:2px}
.links{display:flex;align-items:center;gap:30px}
.links a{font-weight:600;font-size:.92rem;color:var(--ink);position:relative}
.links a::after{content:"";position:absolute;left:0;bottom:-6px;width:0;height:2px;background:var(--wine);transition:.25s}
.links a:hover{color:var(--wine)}
.links a:hover::after{width:100%}
.links .give{background:var(--wine);color:#fff;padding:9px 20px;border-radius:30px}
.links .give::after{display:none}
.links .give:hover{background:var(--wine2);color:#fff}
.burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px}
.burger span{width:24px;height:2.5px;background:var(--ink);border-radius:2px;transition:.3s}

/* hero */
.hero{position:relative;min-height:100vh;display:flex;align-items:flex-start;padding:190px 0 90px;background-image:linear-gradient(180deg,rgba(6,12,9,.42) 0%,rgba(6,12,9,.08) 34%,rgba(6,12,9,0) 56%),linear-gradient(100deg,rgba(8,14,11,.72) 0%,rgba(10,16,13,.48) 42%,rgba(12,20,16,.28) 74%,rgba(14,22,18,.4) 100%),url('data:image/jpeg;base64,');background-size:cover;background-position:center 58%;background-repeat:no-repeat;overflow:hidden}
.hero-grid{position:relative;z-index:2;display:grid;grid-template-columns:1fr;gap:40px;align-items:center}
.eyebrow{display:inline-flex;align-items:center;gap:9px;font-weight:700;font-size:.74rem;letter-spacing:2.5px;
  text-transform:uppercase;color:var(--wine);background:#fff;padding:8px 16px;border-radius:30px;border:1px solid var(--line)}
.hero h1{font-size:clamp(2.6rem,5.4vw,4.3rem);line-height:1.04;font-weight:600;letter-spacing:-1px;margin:22px 0 18px}
.hero h1 em{font-style:italic;color:var(--wine);font-weight:500}
.hero p.lead{font-size:1.05rem;color:var(--ink2);max-width:560px;margin-bottom:30px}
.hero .eyebrow{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.28);backdrop-filter:blur(4px)}
.hero h1{color:#fff}
.hero h1 em{color:#cfe3d6}
.hero p.lead{color:rgba(255,255,255,.85)}
.hero .btn.ghost{color:#fff}
.hero .btn.ghost:hover{color:#e7efe9}
.hero-cta{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.hero-media{position:relative}
.hero-back{display:none}
.hero-card{position:relative;border-radius:24px;overflow:hidden;box-shadow:0 40px 70px -30px rgba(34,42,60,.55);border:6px solid #fff}
.hero-card img{width:100%;height:430px;object-fit:cover}
.play{position:absolute;inset:0;display:grid;place-items:center}
.play span{width:74px;height:74px;border-radius:50%;background:rgba(255,255,255,.92);display:grid;place-items:center;
  box-shadow:0 12px 30px rgba(0,0,0,.3);transition:.25s}
.play span:hover{transform:scale(1.08);background:#fff}
.play svg{width:26px;height:26px;margin-left:4px;fill:var(--wine)}
.hero-tag{position:absolute;left:18px;bottom:18px;background:rgba(34,42,60,.72);backdrop-filter:blur(6px);
  color:#fff;padding:10px 16px;border-radius:14px;font-size:.82rem;font-weight:600}
.hero-tag b{color:#dcc890}
.float{position:absolute;background:var(--card);border:1px solid var(--line);border-radius:18px;padding:14px 18px;
  box-shadow:0 20px 40px -20px rgba(34,42,60,.4);display:flex;align-items:center;gap:12px}
.float .ic{width:38px;height:38px;border-radius:11px;background:var(--blush2);display:grid;place-items:center;color:var(--wine)}
.float .ic svg{width:20px;height:20px}
.float small{display:block;font-size:.68rem;letter-spacing:1px;text-transform:uppercase;color:var(--ink2);font-weight:700}
.float strong{font-size:.95rem}
.float.f1{top:-26px;right:24px}

/* mission */
.mission{background:var(--wine);color:#f7e9ee;padding:70px 0;position:relative;overflow:hidden}
.mission::before{content:"";position:absolute;top:-80px;right:-60px;width:340px;height:340px;
  background:radial-gradient(circle,rgba(255,255,255,.10),transparent 70%)}
.mission .verse{font-family:'Fraunces',serif;font-style:italic;font-size:1.05rem;color:#d6cda2;margin-bottom:18px}
.mission h2{font-size:clamp(1.7rem,3.2vw,2.5rem);font-weight:500;line-height:1.3;max-width:920px;letter-spacing:-.5px}
.mission .who{margin-top:14px;font-weight:700;color:#fff}

/* section base */
section.pad{padding:90px 0}
.head{text-align:center;max-width:640px;margin:0 auto 50px}
.kick{font-weight:700;font-size:.76rem;letter-spacing:3px;text-transform:uppercase;color:var(--wine);margin-bottom:14px}
.head h2{font-size:clamp(2rem,4vw,3rem);font-weight:600;letter-spacing:-1px;line-height:1.1}
.head h2 em{font-style:italic;color:var(--wine)}
.head p{color:var(--ink2);margin-top:14px;font-size:1.02rem}

/* quick nav */
.quick{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}
.qcard{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:30px 24px;text-align:center;
  transition:.3s;position:relative;overflow:hidden}
.qcard:hover{transform:translateY(-6px);box-shadow:0 26px 50px -24px rgba(47,93,79,.5);border-color:var(--rose)}
.qcard . qi,.qcard .qi{width:60px;height:60px;margin:0 auto 18px;border-radius:16px;background:var(--blush2);
  display:grid;place-items:center;color:var(--wine);transition:.3s}
.qcard:hover .qi{background:var(--wine);color:#fff}
.qcard .qi svg{width:28px;height:28px}
.qcard h3{font-size:1.18rem;font-weight:600;margin-bottom:6px}
.qcard p{font-size:.86rem;color:var(--ink2)}
.qcard .go{display:inline-block;margin-top:14px;font-weight:700;font-size:.82rem;color:var(--wine)}

/* welcome split */
.split{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.split .imgwrap{position:relative}
.split .imgwrap img{width:100%;height:480px;object-fit:cover;border-radius:24px;box-shadow:0 36px 60px -30px rgba(34,42,60,.5)}
.split .imgwrap .badge{position:absolute;bottom:-22px;left:-22px;background:var(--wine);color:#fff;border-radius:20px;
  padding:22px 26px;box-shadow:0 24px 40px -18px rgba(47,93,79,.7)}
.split .imgwrap .badge b{font-family:'Fraunces',serif;font-size:2rem;display:block;line-height:1}
.split .imgwrap .badge small{font-size:.78rem;letter-spacing:.5px;opacity:.9}
.split h2{font-size:clamp(2rem,3.6vw,2.8rem);font-weight:600;letter-spacing:-1px;line-height:1.1;margin-bottom:20px}
.split h2 em{font-style:italic;color:var(--wine)}
.split p{color:var(--ink2);margin-bottom:16px}
.vals{list-style:none;margin:24px 0 30px;display:grid;gap:14px}
.vals li{display:flex;gap:12px;align-items:flex-start;font-weight:500}
.vals .chk{flex:none;width:24px;height:24px;border-radius:50%;background:var(--blush2);color:var(--wine);
  display:grid;place-items:center;margin-top:2px}
.vals .chk svg{width:13px;height:13px}

/* visit times */
.visit{background:var(--blush2)}
.times{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:10px}
.tcard{background:var(--cream);border-radius:20px;padding:34px 28px;text-align:center;border:1px solid var(--line)}
.tcard .ti{width:54px;height:54px;margin:0 auto 16px;border-radius:14px;background:var(--wine);color:#fff;display:grid;place-items:center}
.tcard .ti svg{width:26px;height:26px}
.tcard h3{font-size:1.15rem;margin-bottom:6px}
.tcard .time{font-family:'Fraunces',serif;font-size:1.7rem;color:var(--wine);font-weight:600}
.tcard p{font-size:.86rem;color:var(--ink2);margin-top:4px}

/* ministries */
.min-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.mcard{border-radius:22px;overflow:hidden;position:relative;height:300px;box-shadow:0 24px 44px -26px rgba(34,42,60,.5)}
.mcard img{width:100%;height:100%;object-fit:cover;transition:.5s}
.mcard:hover img{transform:scale(1.07)}
.mcard .ov{position:absolute;inset:0;background:linear-gradient(180deg,transparent 30%,rgba(18,36,29,.86));
  display:flex;flex-direction:column;justify-content:flex-end;padding:26px;color:#fff}
.mcard .ov h3{font-size:1.4rem;font-weight:600}
.mcard .ov p{font-size:.88rem;opacity:.92;margin-top:4px}
.mcard.tall{grid-row:span 2;height:auto}

/* gallery strip */
.strip{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.strip img{width:100%;height:220px;object-fit:cover;border-radius:16px;transition:.4s;filter:saturate(1.02)}
.strip img:hover{transform:scale(1.03)}

/* give cta */
.give-cta{position:relative;border-radius:30px;overflow:hidden;margin:0 24px}
.give-cta .bg{position:absolute;inset:0}
.give-cta .bg img{width:100%;height:100%;object-fit:cover}
.give-cta .bg::after{content:"";position:absolute;inset:0;background:linear-gradient(120deg,rgba(33,67,57,.92),rgba(47,93,79,.78))}
.give-cta .inner{position:relative;padding:80px 40px;text-align:center;color:#fff;max-width:680px;margin:0 auto}
.give-cta h2{font-size:clamp(2rem,4vw,3rem);font-weight:600;letter-spacing:-1px;margin-bottom:16px}
.give-cta p{opacity:.92;margin-bottom:30px}
.give-cta .btn{background:#fff;color:var(--wine)}
.give-cta .btn:hover{background:var(--cream)}

/* footer */
footer{background:var(--ink);color:#cdd2dd;padding:70px 0 30px;margin-top:90px}
.fgrid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:40px}
.fcol h4{color:#fff;font-family:'Fraunces',serif;font-size:1.05rem;margin-bottom:18px;font-weight:600}
.fcol .logo b{color:#fff}.fcol .logo span{color:#9aa2b3}
.fcol p{font-size:.92rem;margin-bottom:8px;color:#aab1bf}
.fcol a{font-size:.92rem;color:#aab1bf;display:block;margin-bottom:9px;transition:.2s}
.fcol a:hover{color:#fff;padding-left:4px}
.socials{display:flex;gap:12px;margin-top:18px}
.socials a{width:40px;height:40px;border-radius:11px;background:rgba(255,255,255,.08);display:grid;place-items:center;margin:0}
.socials a:hover{background:var(--wine);padding-left:0}
.socials svg{width:18px;height:18px;fill:#fff}
.fbot{border-top:1px solid rgba(255,255,255,.1);margin-top:50px;padding-top:24px;text-align:center;font-size:.82rem;color:#8b93a4}

/* reveal */
.rv{opacity:0;transform:translateY(28px);transition:.7s cubic-bezier(.2,.7,.2,1)}
.rv.in{opacity:1;transform:none}

@media(max-width:920px){
  .hero-grid,.split{grid-template-columns:1fr;gap:40px}
  .hero-back{display:none}
  .quick{grid-template-columns:repeat(2,1fr)}
  .min-grid{grid-template-columns:1fr 1fr}
  .mcard.tall{grid-row:span 1}
  .strip{grid-template-columns:1fr 1fr}
  .times{grid-template-columns:1fr}
  .fgrid{grid-template-columns:1fr;gap:30px}
  .split .imgwrap .badge{left:14px}
}
@media(max-width:680px){
  .links{position:fixed;inset:0 0 0 auto;width:78%;max-width:320px;background:var(--cream);flex-direction:column;
    align-items:flex-start;justify-content:flex-start;padding:90px 30px;gap:22px;transform:translateX(100%);
    transition:.35s;box-shadow:-20px 0 50px rgba(0,0,0,.2)}
  .links.open{transform:none}
  .burger{display:flex;z-index:60}
  .burger.x span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}
  .burger.x span:nth-child(2){opacity:0}
  .burger.x span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}
  .quick{grid-template-columns:1fr}
  .min-grid,.strip{grid-template-columns:1fr}
  .hero{min-height:100vh;align-items:flex-start;padding:120px 0 70px;
    background-image:linear-gradient(180deg,rgba(8,14,11,.78) 0%,rgba(10,16,13,.52) 36%,rgba(11,18,14,.32) 66%,rgba(9,15,12,.42) 100%),url('data:image/jpeg;base64,');
    background-position:center 58%}
  .hero h1{font-size:clamp(2.3rem,9vw,3.2rem)}
  .hero p.lead{max-width:100%}
}
</style>
</head>
<body>

<div class="ann">SUNDAY SCHOOL <b>10:00 AM</b> &nbsp;&bull;&nbsp; WORSHIP SERVICE <b>10:45 AM</b> &nbsp;&bull;&nbsp; 202 N. 4th Street, Normangee, TX</div>

<header>
  <nav>
    <a class="logo" href="#top">
      <span class="mark"><svg viewBox="0 0 40 40" fill="none"><path d="M20 3v34M11 14h18M8 37h24M11 21v16M29 21v16M14 37V27h12v10" stroke="#2f5d4f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      <span><b>First Bible</b><span>Normangee &middot; Texas</span></span>
    </a>
    <div class="links" id="menu">
      <a href="#top">Home</a>
      <a href="#about">About</a>
      <a href="#visit">Visit</a>
      <a href="#ministries">Ministries</a>
      <a href="#connect">Connect</a>
      <a class="give" href="#give">Give</a>
    </div>
    <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </nav>
</header>

<main id="top">

  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="rv in">
        <span class="eyebrow">&#10022; Welcome Home to First Bible Church</span>
        <h1>A family that <em>worships,</em> serves &amp; witnesses together.</h1>
        <p class="lead">We are called to proclaim and live the Gospel of Christ&mdash;carrying His good news to Normangee and from here to the world. Come as you are. There&rsquo;s a place for you here.</p>
        <div class="hero-cta">
          <a class="btn" href="#visit">Join Us This Sunday <span class="arrow">&#8599;</span></a>
          <a class="btn ghost" href="#connect">Watch Live Stream</a>
        </div>
      </div>
          </div>
  </section>

  <!-- MISSION -->
  <section class="mission">
    <div class="wrap">
      <p class="verse">&ldquo;Go therefore and make disciples of all nations&hellip;&rdquo; &mdash; Matthew 28:19</p>
      <h2>We may not have all the answers, but we <strong>worship, serve, and witness</strong> of the One who does.</h2>
      <p class="who">First Bible Church of Normangee, Texas</p>
    </div>
  </section>

  <!-- QUICK NAV -->
  <section class="pad">
    <div class="wrap">
      <div class="head rv">
        <p class="kick">Get Connected</p>
        <h2>Everything you need, <em>one tap away</em></h2>
      </div>
      <div class="quick">
        <a class="qcard rv" href="#visit">
          <div class="qi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></div>
          <h3>Events</h3><p>See what&rsquo;s happening this week.</p><span class="go">Explore &rarr;</span>
        </a>
        <a class="qcard rv" href="#connect">
          <div class="qi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m23 7-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg></div>
          <h3>Live Stream</h3><p>Worship with us from anywhere.</p><span class="go">Watch &rarr;</span>
        </a>
        <a class="qcard rv" href="#connect">
          <div class="qi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9M13.7 21a2 2 0 0 1-3.4 0"/></svg></div>
          <h3>Notifications</h3><p>Stay in the loop&mdash;sign up.</p><span class="go">Sign up &rarr;</span>
        </a>
        <a class="qcard rv" href="#give">
          <div class="qi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg></div>
          <h3>Give</h3><p>Support the work of the Gospel.</p><span class="go">Give now &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ABOUT / WELCOME -->
  <section class="pad" id="about" style="padding-top:20px">
    <div class="wrap split">
      <div class="imgwrap rv">
        <img src="data:image/jpeg;base64,'s ministry">
          <div class="ov"><h3>Men</h3><p>Brothers sharpening one another.</p></div>
        </a>
        <a class="mcard rv" href="#connect">
          <img src="data:image/jpeg;base64,'s ministry">
          <div class="ov"><h3>Women</h3><p>Fellowship, prayer &amp; encouragement.</p></div>
        </a>
      </div>
    </div>
  </section>

  <!-- GALLERY STRIP -->
  <section style="padding:30px 0 90px">
    <div class="wrap">
      <div class="head rv"><p class="kick">Life Together</p><h2>Moments of <em>worship &amp; joy</em></h2></div>
      <div class="strip rv">
        <img src="data:image/jpeg;base64,'burger'), m=document.getElementById('menu');
  b.addEventListener('click',function(){m.classList.toggle('open');b.classList.toggle('x');});
  m.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){m.classList.remove('open');b.classList.remove('x');});});
  // reveal on scroll
  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.12});
  document.querySelectorAll('.rv').forEach(function(el){io.observe(el);});
</script>
</body>
</html>
